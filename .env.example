# ============================================================
#  Megaphone 📣 — configuration
#  Copy this file to ".env" and fill in your own values.
#  The ".env" file is private and is NEVER uploaded to GitHub.
# ============================================================

# --- Web server ---
PORT=4000

# --- Payment rail ---
# "sim"  = simulated escrow, runs fully offline, no accounts needed (default)
# "croo" = real CROO Agent Protocol on Base (needs the values below)
RAIL=sim

# Protects POST /api/demo (which spends real USDC on hires in croo mode).
# Required in croo mode; pick any long random string.
MEGAPHONE_ADMIN_TOKEN=

# --- AI brain (free) ---
# Any OpenAI-compatible endpoint. Groq (free, fast): https://console.groq.com/keys
# For a local model instead: LLM_BASE_URL=http://localhost:11434/v1  LLM_MODEL=qwen2.5:7b-instruct
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=

# --- CROO (only needed when RAIL=croo) ---
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws

# Megaphone is ONE agent profile in the CROO dashboard — one SDK key.
CROO_MEGAPHONE_SDK_KEY=

# Megaphone's own three listings on the CROO Agent Store (create them in the
# dashboard, then paste each service id here).
CROO_AUDIT_SERVICE_ID=
CROO_KIT_SERVICE_ID=
CROO_CAMPAIGN_SERVICE_ID=

# USDC deposited into Megaphone's wallet (dashboard display only).
CROO_START_BALANCE=2

# --- Hiring policy ---
# Never hire an external service listed above this price (USDC).
MEGAPHONE_MAX_HIRE_PRICE=0.15
# Skip these agentIds when hiring (our own listings are always skipped;
# add sibling agents here to avoid self-trade patterns).
MEGAPHONE_EXCLUDE_AGENT_IDS=
# Optionally pin an exact external serviceId per role (else auto-discovered).
# A pin is a preference, not an override: blocked or benched services stay out.
MEGAPHONE_RESEARCH_SERVICE_ID=
MEGAPHONE_FACTCHECK_SERVICE_ID=
MEGAPHONE_SUMMARIZE_SERVICE_ID=
MEGAPHONE_CONTENT_SERVICE_ID=
# Never hire these (comma-separated, matched inside the service OR agent name).
# Mirai is blocked by default: its "autopost" service bills for a licence key
# instead of publishing anything.
MEGAPHONE_BLOCKED_AGENTS=mirai
# How long a service is benched after it fails to deliver (see hire-history.ts).
MEGAPHONE_FAILURE_COOLDOWN_DAYS=30

# Optional: override the chain RPC (defaults to Base mainnet inside the SDK).
# CROO_RPC_URL=
